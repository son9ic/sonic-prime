<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sonic Seasons - Cave Intro</title>

<style>

body{
    margin:0;
    overflow:hidden;
    background:black;
    font-family:Arial;
}

canvas{
    display:block;
    background:#050510;
}

#cutsceneText{
    position:absolute;
    bottom:30px;
    width:100%;
    text-align:center;
    color:white;
    font-size:28px;
    text-shadow:0 0 10px black;
}

#pauseMenu{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:320px;
    background:rgba(0,0,0,0.9);
    border:3px solid purple;
    padding:20px;
    display:none;
    color:white;
    text-align:center;
}

button{
    width:220px;
    padding:10px;
    margin:10px;
    font-size:18px;
    cursor:pointer;
}

</style>
</head>

<body>

<canvas id="gameCanvas"></canvas>

<div id="cutsceneText">
    THE TEAM ENTERS THE CAVE...
</div>

<div id="pauseMenu">

    <h2>PAUSED</h2>

    <button id="resumeBtn">Resume</button>
    <button id="abandonBtn">Abandon Mission</button>

</div>

<script>

const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let gameState = "cutscene";

let frame = 0;

let freeRoam = false;

let paused = false;

const keys = {};

const sonic = {

    x:150,
    y:canvas.height - 180,
    width:50,
    height:50,
    speed:6

};

const paradoxShard = {

    x:canvas.width - 300,
    y:canvas.height - 220,
    size:80,
    active:true

};

document.addEventListener("keydown", (e) => {

    keys[e.key.toLowerCase()] = true;

    // Pause
    if(e.key === "Escape"){

        paused = !paused;

        document.getElementById("pauseMenu").style.display =
            paused ? "block" : "none";
    }

});

document.addEventListener("keyup", (e) => {

    keys[e.key.toLowerCase()] = false;

});

document.getElementById("resumeBtn").onclick = () => {

    paused = false;

    document.getElementById("pauseMenu").style.display = "none";

};

document.getElementById("abandonBtn").onclick = () => {

    freeRoam = true;

    paused = false;

    document.getElementById("pauseMenu").style.display = "none";

    document.getElementById("cutsceneText").textContent =
        "MISSION ABANDONED - FREE ROAM ENABLED";

};

function drawCave(){

    // Cave background
    ctx.fillStyle = "#0a0014";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    // Rocks
    ctx.fillStyle = "#1d1d2e";

    for(let i = 0; i < canvas.width; i += 150){

        ctx.fillRect(i, canvas.height - 120, 120, 120);

    }

    // Purple cave glow
    ctx.fillStyle = "rgba(180,0,255,0.15)";
    ctx.fillRect(0,0,canvas.width,canvas.height);

}

function drawSonic(){

    ctx.fillStyle = "#0066ff";

    ctx.beginPath();

    ctx.arc(
        sonic.x,
        sonic.y,
        sonic.width/2,
        0,
        Math.PI * 2
    );

    ctx.fill();

}

function drawShard(){

    if(!paradoxShard.active) return;

    ctx.save();

    ctx.translate(paradoxShard.x, paradoxShard.y);

    ctx.shadowBlur = 40;
    ctx.shadowColor = "#bb00ff";

    ctx.fillStyle = "#c266ff";

    ctx.beginPath();

    ctx.moveTo(0,-60);
    ctx.lineTo(40,0);
    ctx.lineTo(0,60);
    ctx.lineTo(-40,0);

    ctx.closePath();

    ctx.fill();

    ctx.restore();

}

function updatePlayer(){

    if(keys["w"]) sonic.y -= sonic.speed;
    if(keys["s"]) sonic.y += sonic.speed;
    if(keys["a"]) sonic.x -= sonic.speed;
    if(keys["d"]) sonic.x += sonic.speed;

    // Collision with shard
    if(!freeRoam && paradoxShard.active){

        const dx = sonic.x - paradoxShard.x;
        const dy = sonic.y - paradoxShard.y;

        const distance = Math.sqrt(dx*dx + dy*dy);

        if(distance < 70){

            paradoxShard.active = false;

            document.getElementById("cutsceneText").textContent =
                "SONIC TOUCHED THE PARADOX SHARD...";

        }

    }

}

function updateCutscene(){

    frame++;

    const text = document.getElementById("cutsceneText");

    if(frame < 150){

        text.textContent =
            "SONIC, TAILS, KNUCKLES, AMY, AND ROUGE ENTER THE CAVE...";

    }
    else if(frame < 300){

        text.textContent =
            "THEY SEARCH FOR DR. EGGMAN IN THE DARKNESS...";

    }
    else if(frame < 420){

        text.textContent =
            "EGGMAN: HAHAHAHAHA! YOU'RE TOO LATE, SONIC!";

    }
    else{

        text.textContent =
            "GAME START - FIND EGGMAN";

        gameState = "gameplay";

    }

}

function gameLoop(){

    ctx.clearRect(0,0,canvas.width,canvas.height);

    drawCave();

    drawShard();

    drawSonic();

    if(!paused){

        if(gameState === "cutscene"){

            updateCutscene();

        }

        if(gameState === "gameplay"){

            updatePlayer();

        }

    }

    requestAnimationFrame(gameLoop);

}

gameLoop();

window.addEventListener("resize", () => {

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

});

</script>

</body>
</html>
